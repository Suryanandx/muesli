# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: anthropic | ollama | openrouter
PROVIDER=anthropic

# Anthropic (default)
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (local — no API key needed, just run `ollama serve`)
# PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenRouter (access many models via one API key)
# PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ── Audio ─────────────────────────────────────────────────────────────────────
# Leave blank for default mic. Set to "BlackHole 2ch" for system audio capture.
# Run: .venv/bin/python -m app.devices  to list available devices
AUDIO_DEVICE=

# ── Transcription ─────────────────────────────────────────────────────────────
# Whisper model: tiny | base | small | medium | large-v3
# Larger = more accurate, slower first load
WHISPER_MODEL=base

# ── Database (optional — leave blank for SQLite local dev) ───────────────────
# Set when running via docker compose (auto-set by docker-compose.yml)
DATABASE_URL=

# ── Cache (optional — Redis, degrades gracefully if not set) ─────────────────
REDIS_URL=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=7474
