{
  "version": 2,
  "name": "muesli",
  "builds": [
    {
      "src": "static/landing.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/styles.css", "dest": "/static/styles.css" },
    { "src": "/logo.svg", "dest": "/static/logo.svg" },
    { "src": "/logo-mark.svg", "dest": "/static/logo-mark.svg" },
    { "src": "/(.*)", "dest": "/static/landing.html" }
  ]
}
